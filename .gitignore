.venv/
__pycache__/
.pytest_cache/
.env
output/
# Invoice PDFs may contain confidential business data - never commit them.
# (Test fixtures are generated on the fly by the test suite.)
samples/*.pdf
.claude/

# Dedicated directories for controlled real-invoice validation milestones -
# never commit real invoice PDFs or their outputs/manifests.
real_invoice_test/
real_invoice_test_*/

# Real-sample pilot workflow (README "Real sample pilot") and scratch output -
# same reasoning: never commit real invoice PDFs.
samples_real/
tmp/

# OpenRouter usage/cost sidecar reports - already covered by output/ when
# written to the default location, but a custom --output path could land
# elsewhere; never commit these regardless.
*.usage.csv

# Benchmark real-data (M6): reports and ground truth may contain expected/
# actual invoice field values - never commit real-data cases or run outputs.
# The committed, synthetic-only examples under benchmark/examples/ stay
# visible (negated below); everything else under benchmark/ is local.
benchmark/manifest.json
benchmark/thresholds.json
benchmark/ground_truth/
benchmark/results/
benchmark_report.xlsx
benchmark_report.json

# Atomic-write temporaries (M7): staged artifacts are written to
# <final>.tmp-<pid>-<n> beside their final path and removed after replace or
# on failure - never commit a stray one if a process was killed mid-write.
*.tmp-*

# Local deployment archives built by scripts/build-release.sh (M8).
release/

# Operator input folder (M8 Docker/native workflow) - holds the user's real
# invoice PDFs; never commit it. Mounted read-only into the container.
input/

# Web UI job data (M9): per-job uploaded PDFs and outputs under a 24h
# retention window - never commit.
web-data/

# macOS Finder metadata
.DS_Store

# Python packaging artifacts
build/
dist/
*.egg-info/
*.py[cod]
