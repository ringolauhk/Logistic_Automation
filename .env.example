# Copy this file to .env and fill in your keys. Never commit .env.
#
# Provider roles are fixed by design - not a "pick Claude or Gemini" choice:
#   GEMINI_API_KEY    required for ALL real extraction (text route, and
#                     vision route primary). Not needed for `doctor`
#                     (offline mode), `classify`, `render`, `--help`, or
#                     importing the package - those never touch a provider.
#   ANTHROPIC_API_KEY optional. Powers the vision-route fallback (used
#                     automatically if Gemini vision fails) and, only if
#                     ENABLE_CLAUDE_TEXT_FALLBACK=true below, the text
#                     route's fallback too. Leave blank to run Gemini-only.
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Models (per route; names are logged at startup, keys never are) -------
# Defaults shown. Verify acceptance with: python -m invoice_extractor doctor --live
#GEMINI_TEXT_MODEL=gemini-flash-latest
#GEMINI_VISION_MODEL=gemini-flash-latest
#CLAUDE_TEXT_MODEL=claude-sonnet-5
#CLAUDE_VISION_MODEL=claude-sonnet-5

# --- Routing ----------------------------------------------------------------
# The original design keeps the text path Gemini-only (vision fallback is
# always on). Enable only if you want Claude to retry failed TEXT extractions.
#ENABLE_CLAUDE_TEXT_FALLBACK=false

# --- Tuning (defaults shown) -------------------------------------------------
#RENDER_DPI=200
#TEXT_QUALITY_THRESHOLD=20
#MAX_VISION_PAGES=5
#MAX_RETRIES=3
#REQUEST_TIMEOUT_SECONDS=120

# --- OpenRouter gateway (optional alternative to the direct Gemini/Claude
#     gateway above) ---------------------------------------------------------
# Set LLM_GATEWAY=openrouter to route BOTH text and vision extraction through
# OpenRouter's ordered model ladders instead of Gemini/Claude. The direct
# gateway (LLM_GATEWAY=direct, the default) is unchanged. Keys are never
# logged; model NAMES are. See docs/OPERATIONS.md for full guidance.
#LLM_GATEWAY=direct
#OPENROUTER_API_KEY=your-openrouter-key-here
# Ordered, comma-separated ladders (first accepted result wins; later entries
# are escalation tiers). A stray/empty entry (e.g. "a,,b" or "a,") is REJECTED,
# not silently dropped. Use neutral example ids and confirm they exist on
# OpenRouter before a real run.
#OPENROUTER_TEXT_MODELS=vendor/text-model-a,vendor/text-model-b
#OPENROUTER_VISION_MODELS=vendor/vision-model-a,vendor/vision-model-b
#OPENROUTER_STRUCTURED_OUTPUT=json_schema
# Bounded text/vision chunking (pages per request). Dense scanned invoices can
# TRUNCATE with several image pages in one request - for a scanned-heavy pilot
# start MAX_VISION_PAGES at 1 or 2 (fewer pages per request = fewer truncations,
# but more paid requests). MAX_TEXT_PAGES similarly bounds text-page requests.
#MAX_TEXT_PAGES=2
# (MAX_VISION_PAGES is shared with the direct gateway; default 5 - see above.)

# --- OpenRouter safety limits (STRONGLY recommended; all unset = no limits) --
# With none of these set, a single large/dense document can issue an unbounded
# number of paid calls (bounded only by chunks x models x retries). `run` and
# `doctor` warn once when all three are unset. Recommended starting points:
#   MAX_MODEL_ATTEMPTS_PER_FILE  cap on model attempts across ALL chunks/routes
#                                of one PDF (start ~3).
#   MAX_COST_USD_PER_FILE        per-PDF reported-cost cap (e.g. 0.05).
#   MAX_COST_USD_PER_RUN         whole-batch reported-cost cap (e.g. 1.00).
# See docs/OPERATIONS.md "Cost control" for the exact paid-call formula.
#MAX_MODEL_ATTEMPTS_PER_FILE=3
#MAX_COST_USD_PER_FILE=0.05
#MAX_COST_USD_PER_RUN=1.00

# --- Pilot web UI (M9; defaults shown) ----------------------------------------
# Single-user Streamlit UI - see docs/WEB_UI.md. No login: keep the port on
# localhost/Tailscale. Uploads/outputs live under WEB_JOBS_DIR per job and are
# deleted after WEB_JOB_RETENTION_HOURS (or via the in-app delete button).
#WEB_MAX_FILES=25
#WEB_MAX_FILE_MB=25
#WEB_MAX_TOTAL_MB=200
#WEB_JOB_RETENTION_HOURS=24
#WEB_JOBS_DIR=./web-data/jobs

# --- Transfer Note Packing List workflow (Build 1; defaults shown) ------------
# Feature-flagged second workflow in the web UI - see
# docs/transfer_packing/FUNCTIONAL_SPEC.md. OFF by default: when disabled, the
# invoice UI is unchanged and no workflow selector is shown. Build 1 only
# uploads and validates Transfer Delivery Note PDFs (no extraction, no product
# API, no Excel output yet). Transfer jobs are stored separately from invoice
# jobs and are not auto-deleted in Build 1.
#TRANSFER_WORKFLOW_ENABLED=false
#TRANSFER_MAX_FILES=50
#TRANSFER_MAX_FILE_MB=50
#TRANSFER_MAX_PAGES=500
#TRANSFER_JOBS_DIR=./web-data/transfer-jobs

# --- API Gateway authentication (Transfer workflow, Build 4) -------------------
# BACKEND-ONLY settings for the future product lookup (Build 5). Tokens are
# cached in server memory only - never persisted, never sent to the browser,
# never written to job/review artifacts or logs. Success requires BOTH
# HTTP 2xx AND the gateway envelope code (default 100000). Placeholders only:
# NEVER commit real credentials, and never bake them into Docker images.
#API_GATEWAY_BASE_URL=https://websrv.imaginex.hk:8443/devgapi
#API_GATEWAY_LOGIN_PATH=/auth/login
#API_GATEWAY_REFRESH_PATH=/auth/refresh
#API_GATEWAY_CLIENT_ID=Web-Label
#API_GATEWAY_SUCCESS_CODE=100000
#API_GATEWAY_TIMEOUT_SECONDS=30
#API_GATEWAY_MAX_AUTH_RETRIES=2
#API_GATEWAY_EXPIRY_SKEW_SECONDS=60
#API_GATEWAY_LOCALE=en-US
#API_GATEWAY_USER_ID=your-gateway-user-id
#API_GATEWAY_PASSWORD=your-gateway-password

# --- Validation tolerances ---------------------------------------------------
#TOTAL_ABS_TOLERANCE=0.02
#TOTAL_REL_TOLERANCE=0.005

# --- Debugging ---------------------------------------------------------------
# WARNING: when enabled, raw provider responses for FAILED extractions
# (malformed JSON even after one repair retry, or missing required fields)
# are persisted to DEBUG_ARTIFACT_DIR - never for successful ones. These
# files MAY CONTAIN FULL INVOICE CONTENTS - confidential business data. Keep
# disabled unless actively debugging, and NEVER commit DEBUG_ARTIFACT_DIR
# (the default ./output/debug is already covered by output/ in .gitignore;
# if you point this at a custom path outside output/, git-ignore it too).
#SAVE_DEBUG_ARTIFACTS=false
#DEBUG_ARTIFACT_DIR=./output/debug
